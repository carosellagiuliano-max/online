# ===========================================
# BeautifyPRO Demo - Local Presentation Environment
# ===========================================
# This file is intentionally demo-only. Do not use it for production secrets.

APP_NAME=frontend-schnittwerk
CONTAINER_PREFIX=beauty
TRAEFIK_ROUTER_PREFIX=beauty
APP_DOMAIN=beautifypro.demo
SUPABASE_DOMAIN=api.beautifypro.demo
STUDIO_DOMAIN=studio.beautifypro.demo
STUDIO_PROJECT_NAME=BeautifyPRO Demo

POSTGRES_PASSWORD=postgres
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# Mock placeholders only. Replace with generated local Supabase JWTs if you run the DB stack.
ANON_KEY=beautifypro-demo-anon-key-local-only
NEXT_PUBLIC_SUPABASE_ANON_KEY=beautifypro-demo-anon-key-local-only
SERVICE_ROLE_KEY=beautifypro-demo-service-role-key-local-only
SUPABASE_SERVICE_ROLE_KEY=beautifypro-demo-service-role-key-local-only
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

NEXT_PUBLIC_DOMAIN=localhost
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_EMAIL_AUTOCONFIRM=true
SECRET_KEY_BASE=beautifypro-demo-secret-key-base-local-only
FUNCTIONS_VERIFY_JWT=false

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@beautifypro.demo
SMTP_ADMIN_EMAIL=demo@beautifypro.demo
EMAIL_TO=demo@beautifypro.demo

ENABLE_WIZARD=false
NEXT_PUBLIC_MOCK_MODE=true

PAYMENT_PROVIDER=pay_at_venue
NEXT_PUBLIC_PAYMENT_PROVIDER=pay_at_venue
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

NEXT_PUBLIC_FEATURE_SHOP_ENABLED=true
NEXT_PUBLIC_FEATURE_BOOKING_ENABLED=true
NEXT_PUBLIC_FEATURE_GALLERY_ENABLED=true
NEXT_PUBLIC_FEATURE_NOTIFICATION_TEMPLATES_ENABLED=true
NEXT_PUBLIC_FEATURE_FINANCE_ENABLED=true
NEXT_PUBLIC_THEME=ocean
NEXT_PUBLIC_THEME_STRUCTURE=classic

ADMIN_EMAIL=admin@beautifypro.demo
ADMIN_PASSWORD=beauty-admin-demo
ADMIN_FIRST_NAME=Alex
ADMIN_LAST_NAME=Demo

SUPERADMIN_ENABLED=false
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
